@model BeautyStoreApp.Models.OrderDetail

@{
    ViewData["Title"] = "Edit Qty";
}

<div class="container">

    <h2>Edit Qty</h2>

    <form asp-action="EditDetail" method="post">

        <input asp-for="Id" type="hidden"/>

        <input asp-for="OrderHeaderId" type="hidden"/>

        <input asp-for="ProductId" type="hidden"/>

        <input asp-for="Price" type="hidden"/>

        <div class="mb-3">

            <label>Produk</label>

            <input class="form-control"
                   value="@Model.Product?.Name"
                   readonly/>

        </div>

        <div class="mb-3">

            <label asp-for="Qty"></label>

            <input asp-for="Qty"
                   class="form-control"/>

            <span asp-validation-for="Qty"
                  class="text-danger"></span>

        </div>

        <button class="btn btn-warning">

            Update

        </button>

        <a asp-action="Detail"
           asp-route-id="@Model.OrderHeaderId"
           class="btn btn-secondary">

            Kembali

        </a>

    </form>

</div>

@section Scripts{

    <partial name="_ValidationScriptsPartial"/>

}