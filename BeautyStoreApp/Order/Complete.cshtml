@model BeautyStoreApp.Models.OrderHeader

@{
    ViewData["Title"] = "Selesaikan Pesanan";
}

<div class="container">

    <h2>Selesaikan Pesanan</h2>

    <div class="alert alert-warning">

        Setelah pesanan diselesaikan:

        <ul>
            <li>Status menjadi <b>Completed</b></li>
            <li>Stok produk akan berkurang</li>
            <li>Pesanan tidak boleh diubah lagi</li>
        </ul>

    </div>

    <table class="table table-bordered">

        <tr>
            <th>Nomor Order</th>
            <td>@Model.OrderNumber</td>
        </tr>

        <tr>
            <th>Customer</th>
            <td>@Model.Customer?.FullName</td>
        </tr>

        <tr>
            <th>Total</th>
            <td>Rp @Model.TotalAmount.ToString("N0")</td>
        </tr>

    </table>

    <form asp-action="Complete">

        <input asp-for="Id" type="hidden"/>

        <button class="btn btn-success">

            Ya, Selesaikan

        </button>

        <a asp-action="Detail"
           asp-route-id="@Model.Id"
           class="btn btn-secondary">

            Batal

        </a>

    </form>

</div>