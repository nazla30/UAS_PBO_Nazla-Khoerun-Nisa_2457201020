@model BeautyStoreApp.Models.OrderHeader

@{
    ViewData["Title"] = "Detail Pesanan";
}

<div class="container">

    <h2 class="mb-4">Detail Pesanan</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    <div class="d-flex justify-content-between mb-4">

        <div></div>

        @if (Model.Status != "Completed")
        {
            <a asp-action="AddProduct"
               asp-route-id="@Model.Id"
               class="btn btn-success">

                + Tambah Produk

            </a>
        }

    </div>

    <table class="table table-bordered">

        <tr>
            <th width="220">Nomor Order</th>
            <td>@Model.OrderNumber</td>
        </tr>

        <tr>
            <th>Tanggal</th>
            <td>@Model.OrderDate.ToString("dd MMMM yyyy")</td>
        </tr>

        <tr>
            <th>Customer</th>
            <td>@Model.Customer?.FullName</td>
        </tr>

        <tr>
            <th>Status</th>
            <td>

                @if (Model.Status == "Completed")
                {
                    <span class="badge bg-success">
                        Completed
                    </span>
                }
                else
                {
                    <span class="badge bg-warning text-dark">
                        @Model.Status
                    </span>
                }

            </td>
        </tr>

    </table>

    <h4 class="mt-4 mb-3">

        Daftar Produk

    </h4>

    <table class="table table-bordered table-striped">

        <thead class="table-dark">

            <tr>

                <th>Produk</th>
                <th width="150">Harga</th>
                <th width="80">Qty</th>
                <th width="170">Subtotal</th>
                <th width="200">Aksi</th>

            </tr>

        </thead>

        <tbody>

            @if (Model.OrderDetails != null && Model.OrderDetails.Any())
            {
                foreach (var item in Model.OrderDetails)
                {

                    <tr>

                        <td>@item.Product?.Name</td>

                        <td>
                            Rp @item.Price.ToString("N0")
                        </td>

                        <td>
                            @item.Qty
                        </td>

                        <td>
                            Rp @((item.Price * item.Qty).ToString("N0"))
                        </td>

                        <td>

                            @if (Model.Status != "Completed")
                            {
                                <a asp-action="EditDetail"
                                   asp-route-id="@item.Id"
                                   class="btn btn-warning btn-sm">

                                    Edit

                                </a>

                                <a asp-action="DeleteDetail"
                                   asp-route-id="@item.Id"
                                   class="btn btn-danger btn-sm">

                                    Hapus

                                </a>
                            }
                            else
                            {
                                <span class="text-success fw-bold">

                                    ✔ Selesai

                                </span>
                            }

                        </td>

                    </tr>

                }
            }
            else
            {
                <tr>

                    <td colspan="5" class="text-center">

                        Belum ada produk.

                    </td>

                </tr>
            }

        </tbody>

    </table>

    <div class="card mt-4 shadow">

        <div class="card-body text-end">

            <h4 class="text-success">

                Grand Total

            </h4>

            <h2>

                Rp @Model.TotalAmount.ToString("N0")

            </h2>

        </div>

    </div>

    <hr />

    <div class="d-flex gap-2 flex-wrap mt-4">

        <a asp-action="Index"
           class="btn btn-secondary">

            Kembali

        </a>

        @if (Model.Status != "Completed")
        {
            <a asp-action="Complete"
               asp-route-id="@Model.Id"
               class="btn btn-primary">

                Selesaikan Order

            </a>
        }

        <a asp-action="Invoice"
           asp-route-id="@Model.Id"
           class="btn btn-info text-white">

            Lihat Invoice

        </a>

        <a asp-action="DownloadInvoice"
           asp-route-id="@Model.Id"
           class="btn btn-danger">

            Download Invoice PDF

        </a>

    </div>

</div>