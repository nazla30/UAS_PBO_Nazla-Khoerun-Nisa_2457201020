@model BeautyStoreApp.Models.Product

<div class="container">

    <h2>Hapus Produk</h2>

    <div class="alert alert-danger">

        Apakah Anda yakin ingin menghapus produk ini?

    </div>

    <dl class="row">

        <dt class="col-sm-3">

            Nama Produk

        </dt>

        <dd class="col-sm-9">

            @Model.Name

        </dd>

        <dt class="col-sm-3">

            Harga

        </dt>

        <dd class="col-sm-9">

            @Model.Price

        </dd>

    </dl>

    <form asp-action="Delete">

        <input asp-for="Id" type="hidden" />

        <button class="btn btn-danger">

            Hapus

        </button>

        <a asp-action="Index" class="btn btn-secondary">

            Batal

        </a>

    </form>

</div>